/* Solari — warm gold, human-descended */
:root {
    --color-primary: #FFD700;
    --color-secondary: #FFA500;
    --color-bg: rgba(26, 20, 8, 0.92);
    --color-border: #4A3A20;
    --color-text: #F5E6C8;
    --color-text-dim: rgba(245, 230, 200, 0.6);
    --color-glow: #FFE066;
    --color-danger: #FF4444;
    --color-success: #66FF66;
}
